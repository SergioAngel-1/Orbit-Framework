# ============================================================================
#  Headless Web Ecosystem — .gitignore
#  Estructura: /backend (WordPress) + /frontend (Next.js) + Docker
# ============================================================================

# ---------- Entornos ----------
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local
!**/.env.example

# ---------- Secretos / claves ----------
*.pem
*.key
*.cert
*.ppk
SitegroundAccess/

# ============================================================================
#  BACKEND — WordPress
# ============================================================================
# Solo versionamos nuestro código propio (mu-plugins, config, scripts).
# Todo lo que WordPress descarga/genera se ignora.
backend/wp-content/plugins/*
backend/wp-content/themes/*
backend/wp-content/upgrade/
backend/wp-content/uploads/*
!backend/wp-content/uploads/.gitkeep
backend/wp-content/cache/
backend/wp-content/languages/
backend/wp-content/advanced-cache.php
backend/wp-content/object-cache.php
backend/wp-content/db.php
backend/wp-content/hwe-backup-config.json

# Mantén nuestro mu-plugin headless versionado
!backend/wp-content/mu-plugins/
!backend/wp-content/mu-plugins/**

# ============================================================================
#  FRONTEND — Next.js
# ============================================================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Tests / cobertura / Playwright (Fase 8)
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/blob-report/
frontend/.playwright/

# ============================================================================
#  Bases de datos / dumps
# ============================================================================
*.sql
*.sql.gz
*.sqlite
*.db
*.dump

# ============================================================================
#  Logs
# ============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
debug.log
error_log

# ============================================================================
#  Sistema operativo
# ============================================================================
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================================
#  IDE / Editores
# ============================================================================
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
*.code-workspace
*.sublime-project
*.sublime-workspace

# ============================================================================
#  Claude Code
# ============================================================================
.claude/
*.claude-session

# ============================================================================
#  Temporales
# ============================================================================
*.tmp
*.temp
*.swp
*.bak
*.cache
