# ============================================================================
#  .env (RAÍZ) — Variables compartidas por docker-compose
#  Copia este archivo a `.env` y ajusta los valores:
#      cp .env.example .env
# ============================================================================

# ---------- Base de datos (compartida db + wordpress + wpcli) ----------
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=root

# ---------- Puertos publicados en el host ----------
WORDPRESS_PORT=8080
FRONTEND_PORT=3000

# ---------- WordPress ----------
WORDPRESS_DEBUG=1
WP_ENVIRONMENT_TYPE=local
# URL pública con la que se accede a WordPress desde el navegador
WORDPRESS_PUBLIC_URL=http://localhost:8080
# URL del frontend (usada por la redirección headless y como fallback de CORS)
HEADLESS_FRONTEND_URL=http://localhost:3000
# Allowlist de orígenes CORS para WPGraphQL (lista separada por comas).
# En producción: solo tus dominios reales, p. ej.
#   https://tienda.tu-dominio.com,https://www.tu-dominio.com
HEADLESS_ALLOWED_ORIGINS=http://localhost:3000

# ---------- Datos del administrador (los consume wpcli/setup.sh) ----------
WP_TITLE=Headless Web Ecosystem
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com

# ---------- Seguridad / Autenticación ----------
# Secreto JWT usado por AMBOS lados: WordPress firma los tokens y el frontend
# verifica su firma localmente. DEBEN coincidir.
# IMPORTANTE: genera una clave aleatoria larga para producción.
# Ej: openssl rand -base64 64
GRAPHQL_JWT_AUTH_SECRET_KEY=changeme-super-secret-jwt-key

# Cookies de sesión (opcionales; valores por defecto si se omiten)
# AUTH_COOKIE_NAME=hwe_at
# JWT_REFRESH_COOKIE_NAME=hwe_rt
# REFRESH_TOKEN_MAX_AGE_DAYS=30
# COOKIE_DOMAIN=.tu-dominio.com   # para compartir sesión entre subdominios

# Secreto para firmar los tokens CSRF (signed double-submit cookie).
# Genera uno propio: openssl rand -base64 32
CSRF_SECRET=changeme-super-secret-csrf-key

# ---------- Frontend (Next.js) ----------
# Endpoint accesible desde el NAVEGADOR del usuario
NEXT_PUBLIC_WORDPRESS_API_URL=http://localhost:8080/graphql
# Endpoint accesible desde el SERVIDOR Next (red interna Docker)
WORDPRESS_INTERNAL_API_URL=http://wordpress:80/graphql
# Origen autorizado del frontend para CSRF / verificación de Origin (Fases 1 y 4)
ALLOWED_ORIGIN=http://localhost:3000

# ---------- Redis (cache / rate-limit / idempotencia) ----------
# Por la red interna de Docker. Fuera de Docker: redis://localhost:6379
REDIS_URL=redis://redis:6379

# ---------- WooCommerce (proxy inverso — Fase 3) ----------
# Endpoints resueltos por la red interna de Docker (server-to-server).
WC_API_URL=http://wordpress:80/wp-json/wc/v3
WC_STORE_API_URL=http://wordpress:80/wp-json/wc/store/v1
# Credenciales ck/cs SOLO de servidor (NO usar prefijo NEXT_PUBLIC_).
# Genéralas tras instalar WooCommerce con:
#   docker compose run --rm --entrypoint /bin/sh wpcli /scripts/generate-woo-keys.sh
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
# Secreto del webhook de WooCommerce -> revalidación on-demand del catálogo
# (Fase 5). Crea el webhook apuntando a http://frontend:3000/api/revalidate.
# Genera uno: openssl rand -hex 32
WC_WEBHOOK_SECRET=changeme-super-secret-webhook-key

# ---------- HWE Control Center (Plugin de configuración central) ----------
# Secreto compartido entre WordPress y Next.js para revalidar el tag `site-config`
# cuando se guardan cambios desde el panel de administración.
# Genera uno: openssl rand -hex 32
HWE_REVALIDATION_SECRET=changeme-hwe-revalidation-secret

# ---------- Pagos: capa de pasarelas agnóstica (Fase 7) ----------
# Pasarela activa y moneda. `noop` = sandbox sin cobro real (valida el flujo).
PAYMENT_PROVIDER=noop            # noop | wompi | payu | bold | …
PAYMENT_CURRENCY=COP
# URL de retorno del usuario tras el checkout alojado (solo UX, NO prueba de pago).
NEXT_PUBLIC_PAYMENT_RETURN_URL=http://localhost:3000/checkout/return
# Secreto del proveedor de ejemplo `noop` para firmar webhooks de sandbox.
NOOP_INTEGRITY_SECRET=noop-sandbox-secret
# Credenciales por proveedor (SOLO servidor; rellenar al integrar uno):
# WOMPI_PRIVATE_KEY=  WOMPI_INTEGRITY_SECRET=  WOMPI_EVENTS_SECRET=
#   NEXT_PUBLIC_WOMPI_PUBLIC_KEY=   (solo si se usa widget)
# PAYU_MERCHANT_ID=  PAYU_API_KEY=  PAYU_ACCOUNT_ID=
# BOLD_IDENTITY_KEY=  BOLD_SECRET_KEY=

# ---------- URL/Nombre públicos del sitio (usados por auth/analítica) ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Headless Web Ecosystem

# ---------- Analítica (carga condicionada al consentimiento) ----------
# Proveedor: "plausible" | "ga4" | vacío (desactivado).
NEXT_PUBLIC_ANALYTICS_PROVIDER=
# Plausible: dominio registrado y (opcional) host self-hosted.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io
# GA4: ID de medición (G-XXXXXXXX) si usas ga4.
# NEXT_PUBLIC_GA_ID=

# ---------- 2FA (cifrado en reposo del secreto TOTP) ----------
# Clave dedicada para cifrar el secreto 2FA en WordPress (AES-256-GCM).
# Si se omite, se deriva de AUTH_KEY. Genera una: openssl rand -base64 48
# HWE_2FA_KEY=

# ---------- Notificaciones operativas de pedido (opcional) ----------
# Webhook interno (Slack/Teams/ERP/cola) al que el BFF notifica eventos de
# pedido (creado / pagado / cancelado). Los emails AL CLIENTE los envía
# WooCommerce de forma nativa; esto es para operaciones, no para el cliente.
# ORDER_NOTIFICATION_WEBHOOK_URL=

# ---------- Endurecimiento (Fase de seguridad §3) ----------
# Nº de proxies de confianza delante de la app (Caddy=1). Determina cómo se
# calcula la IP real del cliente desde X-Forwarded-For (anti-spoofing del XFF).
# En el frontend (Next): TRUSTED_PROXY_COUNT. En WordPress se define la
# constante HWE_TRUSTED_PROXY_COUNT (wp-config / WORDPRESS_CONFIG_EXTRA).
TRUSTED_PROXY_COUNT=1
# Clave DEDICADA para cifrar los secretos del HWE Control Center (AES-256-GCM).
# Desacoplada del secreto JWT (rotar el JWT ya no inutiliza los secretos).
# Si se omite, se deriva de AUTH_KEY. Genera una: openssl rand -base64 48
# HWE_SECRETS_KEY=
#
# NOTA: en producción el guard de arranque ABORTA si GRAPHQL_JWT_AUTH_SECRET_KEY,
# CSRF_SECRET, WC_WEBHOOK_SECRET o HWE_REVALIDATION_SECRET siguen con valores
# por defecto o miden menos de 24 caracteres. Genera secretos reales.
