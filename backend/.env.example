# ============================================================================
#  backend/.env.example — Variables específicas del backend WordPress
#  (referencia local; en el flujo Docker estas variables viven en el .env raíz
#   y se inyectan vía docker-compose. Úsalo si ejecutas WP-CLI fuera de Docker).
# ============================================================================

# ---------- Conexión a la base de datos ----------
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress

# ---------- Identidad del sitio ----------
WP_URL=http://localhost:8080
WP_TITLE=Headless Web Ecosystem

# ---------- Administrador ----------
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com

# ---------- Headless / GraphQL ----------
# Clave para WPGraphQL JWT Authentication (debe coincidir con la del .env raíz)
GRAPHQL_JWT_AUTH_SECRET_KEY=changeme-super-secret-jwt-key
# Origen permitido por CORS para la API de GraphQL
HEADLESS_FRONTEND_URL=http://localhost:3000
