# ============================================================================
#  .env.prod — Variables de producción
#  Copia a `.env` (o nombre que prefieras) y completa TODOS los valores.
#  Nunca commitees este archivo con secretos reales.
#
#  Úsalo junto a docker-compose.prod.yml:
#      docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================================

# ── Dominio público y HTTPS (Let's Encrypt) ──────────────────────────────────
PUBLIC_DOMAIN=tienda.mi-dominio.com
ACME_EMAIL=admin@mi-dominio.com

# ── Base de datos ─────────────────────────────────────────────────────────────
# ⚠ Usa contraseñas largas y aleatorias en producción.
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=CAMBIA_ESTO_contraseña_larga
MYSQL_ROOT_PASSWORD=CAMBIA_ESTO_root_contraseña_larga

# ── WordPress ─────────────────────────────────────────────────────────────────
WORDPRESS_DEBUG=0
WP_ENVIRONMENT_TYPE=production
WORDPRESS_PUBLIC_URL=https://tienda.mi-dominio.com
HEADLESS_FRONTEND_URL=https://tienda.mi-dominio.com
HEADLESS_ALLOWED_ORIGINS=https://tienda.mi-dominio.com
WP_TITLE=Mi Tienda
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=CAMBIA_ESTO_admin_pass
WP_ADMIN_EMAIL=admin@mi-dominio.com

# ── Seguridad / Autenticación ─────────────────────────────────────────────────
# Genera: openssl rand -base64 64
GRAPHQL_JWT_AUTH_SECRET_KEY=CAMBIA_ESTO_clave_jwt_muy_larga
# Genera: openssl rand -base64 32
CSRF_SECRET=CAMBIA_ESTO_csrf_secret

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_WORDPRESS_API_URL=https://tienda.mi-dominio.com/graphql
NEXT_PUBLIC_SITE_URL=https://tienda.mi-dominio.com
# Imagen del frontend construida para producción:
#   docker build --target prod -t hwe-frontend:prod ./frontend
FRONTEND_IMAGE=hwe-frontend:prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── WooCommerce ───────────────────────────────────────────────────────────────
WC_API_URL=http://wordpress:80/wp-json/wc/v3
WC_STORE_API_URL=http://wordpress:80/wp-json/wc/store/v1
# Genera con: docker compose run --rm --entrypoint /bin/sh wpcli /scripts/generate-woo-keys.sh
WC_CONSUMER_KEY=ck_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WC_CONSUMER_SECRET=cs_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Genera: openssl rand -hex 32
WC_WEBHOOK_SECRET=CAMBIA_ESTO_webhook_secret

# ── HWE Control Center ────────────────────────────────────────────────────────
# Genera: openssl rand -hex 32
HWE_REVALIDATION_SECRET=CAMBIA_ESTO_hwe_revalidation_secret

# ── Pagos ─────────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=noop
PAYMENT_CURRENCY=EUR
NEXT_PUBLIC_PAYMENT_RETURN_URL=https://tienda.mi-dominio.com/checkout/return
NOOP_INTEGRITY_SECRET=noop-sandbox-secret

# ── Backups ───────────────────────────────────────────────────────────────────
# Días de retención local (sincroniza a S3/rclone para retención larga).
BACKUP_RETAIN_DAYS=30
