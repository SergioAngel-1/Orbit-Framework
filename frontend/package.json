{
  "name": "hwe-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend Next.js (App Router) para el ecosistema Headless WordPress + WPGraphQL",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md}": "prettier --write"
  },
  "dependencies": {
    "@sentry/nextjs": "^8.55.2",
    "ioredis": "5.4.2",
    "isomorphic-dompurify": "2.20.0",
    "jose": "5.9.6",
    "next": "15.1.6",
    "next-intl": "^4.13.0",
    "otplib": "^13.4.1",
    "pino": "^9.6.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "9.18.0",
    "eslint-config-next": "15.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
