{
  "name": "hwe-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend Next.js (App Router) para el ecosistema Headless WordPress + WPGraphQL",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@sentry/nextjs": "^10.59.0",
    "@swc/helpers": "^0.5.23",
    "country-flag-icons": "^1.6.20",
    "ioredis": "5.11.1",
    "isomorphic-dompurify": "3.18.0",
    "jose": "6.2.3",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "otplib": "^13.4.1",
    "pino": "^10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "@sentry/cli@2.58.6": true,
    "@swc/core@1.15.41": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
