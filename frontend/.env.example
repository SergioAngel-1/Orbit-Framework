# ============================================================================
#  frontend/.env.example — Variables del frontend Next.js
#  Copia a `.env.local` para desarrollo fuera de Docker:
#      cp .env.example .env.local
# ============================================================================

# Endpoint de GraphQL accesible desde el NAVEGADOR (componentes cliente).
# Debe llevar el prefijo NEXT_PUBLIC_ para exponerse al bundle del cliente.
NEXT_PUBLIC_WORDPRESS_API_URL=http://localhost:8080/graphql

# Endpoint de GraphQL accesible desde el SERVIDOR Next (SSR / ISR / RSC).
# Dentro de Docker usa el hostname interno del servicio: http://wordpress:80/graphql
# Fuera de Docker apunta a localhost.
WORDPRESS_INTERNAL_API_URL=http://localhost:8080/graphql

# ---------- Seguridad (Fases 1 y 4) ----------
# Origen autorizado del propio frontend (verificación de Origin / CSRF).
ALLOWED_ORIGIN=http://localhost:3000

# ---------- Autenticación JWT (Fase 2) ----------
# Secreto JWT compartido con WordPress (server-only, SIN prefijo NEXT_PUBLIC_).
# El frontend verifica la firma de los tokens localmente. DEBE coincidir con el
# GRAPHQL_JWT_AUTH_SECRET_KEY de WordPress.
GRAPHQL_JWT_AUTH_SECRET_KEY=changeme-super-secret-jwt-key
# Nombres y vida de las cookies de sesión (opcionales).
# AUTH_COOKIE_NAME=hwe_at
# JWT_REFRESH_COOKIE_NAME=hwe_rt
# REFRESH_TOKEN_MAX_AGE_DAYS=30
# COOKIE_DOMAIN=.tu-dominio.com

# ---------- Redis (cache / rate-limit / idempotencia) ----------
# Dentro de Docker: redis://redis:6379 — fuera de Docker: redis://localhost:6379
REDIS_URL=redis://localhost:6379
