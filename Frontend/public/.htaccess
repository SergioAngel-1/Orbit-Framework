RewriteEngine On

# ============================================
# Permitir crawlers de redes sociales (Facebook, Twitter, LinkedIn, WhatsApp)
# Necesario para que las imágenes OG se muestren correctamente
# ============================================
<IfModule mod_setenvif.c>
    SetEnvIfNoCase User-Agent "facebookexternalhit" SOCIAL_CRAWLER
    SetEnvIfNoCase User-Agent "Facebot" SOCIAL_CRAWLER
    SetEnvIfNoCase User-Agent "Twitterbot" SOCIAL_CRAWLER
    SetEnvIfNoCase User-Agent "LinkedInBot" SOCIAL_CRAWLER
    SetEnvIfNoCase User-Agent "WhatsApp" SOCIAL_CRAWLER
    SetEnvIfNoCase User-Agent "Slackbot" SOCIAL_CRAWLER
    SetEnvIfNoCase User-Agent "TelegramBot" SOCIAL_CRAWLER
</IfModule>

# Redireccionar de www a no-www
RewriteCond %{HTTP_HOST} ^www\.floresinc\.co [NC]
RewriteRule ^(.*)$ https://floresinc.co/$1 [L,R=301]

# ============================================
# SEO: Club Cannábico Legal en Colombia
# Indexación habilitada para motores de búsqueda
# ============================================

# Headers de seguridad y SEO
<IfModule mod_headers.c>
    # CORS restrictivo - Solo dominios autorizados
    # El backend (admin.floresinc.co) maneja CORS para API requests
    # Este .htaccess es para el frontend estático (floresinc.co)
    SetEnvIf Origin "^https://floresinc\.co$" CORS_ALLOW_ORIGIN=$0
    SetEnvIf Origin "^https://admin\.floresinc\.co$" CORS_ALLOW_ORIGIN=$0
    SetEnvIf Origin "^https://portfolio\.sergioja\.com$" CORS_ALLOW_ORIGIN=$0
    Header set Access-Control-Allow-Origin "%{CORS_ALLOW_ORIGIN}e" env=CORS_ALLOW_ORIGIN
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization"
    Header set Vary "Origin"
    
    # SEO: Permitir indexación (páginas públicas)
    # Las páginas privadas se controlan via meta tags dinámicos
    Header set X-Robots-Tag "index, follow"
    
    # Cache para assets estáticos (mejora SEO y rendimiento)
    <FilesMatch "\.(ico|pdf|jpg|jpeg|png|gif|webp|svg|js|css|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # HTML: cache corto para og/*.html (social crawlers)
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=600, must-revalidate"
    </FilesMatch>
    
    # index.html: Excluir del Dynamic Cache de SiteGround
    # "private" es la directiva que SiteGround reconoce para excluir del SuperCacher
    # Ref: https://es.siteground.com/kb/deshabilitar-cache-dinamica/
    # Si se cachea una versión rota del SPA entry point, toda la app se cae
    <Files "index.html">
        Header set Cache-Control "private, no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </Files>

    # Cabeceras de seguridad (no disruptivas)
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), fullscreen=(self)"

    # CSP en modo enforcement completo - HARDENED
    # React usa Vite que genera hashes para scripts, pero permite inline styles para styled-components
    # NOTA: Si Vite genera scripts inline, agregar nonces o hashes específicos
    # Wompi: checkout.wompi.co para widget de pagos, sandbox.wompi.co para pruebas, production.wompi.co para producción
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://checkout.wompi.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https://admin.floresinc.co https://floresinc.co https://checkout.wompi.co data: blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://admin.floresinc.co https://sandbox.wompi.co https://production.wompi.co; frame-src 'self' https://checkout.wompi.co; frame-ancestors https://portfolio.sergioja.com; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"

    # HSTS solo sobre HTTPS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
</IfModule>

# ============================================
# OG Meta Tags: Servir páginas pre-renderizadas a bots sociales
# Generadas por: node scripts/generate-og-pages.js
# ============================================
RewriteCond %{HTTP_USER_AGENT} facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|Slackbot|TelegramBot|Discordbot|Pinterest|Googlebot [NC]
