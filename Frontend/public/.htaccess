# ============================================
# Plantilla E-Commerce - Frontend .htaccess
# Apache configuration para SPA React + SEO
# ============================================

RewriteEngine On
RewriteBase /

# ============================================
# SPA Fallback: Todas las rutas van a index.html
# ============================================

# No reescribir archivos estáticos reales
RewriteRule ^index\.html$ - [L]

# Rutas con prefijo /en/ (idioma inglés) → SPA
RewriteRule ^en(/.*)?$ /index.html [L]

# Rutas de catálogo y búsqueda → SPA
RewriteRule ^catalogo(/.*)?$ /index.html [L]
RewriteRule ^catalog(/.*)?$ /index.html [L]

# Fallback general: cualquier ruta que no sea archivo/directorio real → SPA
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# ============================================
# Headers de seguridad y rendimiento
# ============================================
<IfModule mod_headers.c>
    # CORS restrictivo
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization"
    Header set Vary "Origin"
    
    # Cache para assets estáticos
    <FilesMatch "\.(ico|pdf|jpg|jpeg|png|gif|webp|svg|js|css|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # HTML: cache corto para revalidación
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=600, must-revalidate"
    </FilesMatch>
    
    # index.html: Sin cache para evitar versión rota del SPA
    <Files "index.html">
        Header set Cache-Control "private, no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </Files>

    # Cabeceras de seguridad
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), fullscreen=(self)"

    # CSP - Configurar según necesidades del proyecto
    # Incluye: self, Google Fonts, y dominios de pasarelas de pago
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https://placehold.co data: blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self'; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"

    # HSTS solo sobre HTTPS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
</IfModule>