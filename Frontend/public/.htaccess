# ============================================
# Reglas SPA para React (usuarios normales)
# ============================================

# Redirigir URLs con prefijo /en/ de los sitemaps al path canónico (sin prefijo)
# Los sitemaps se sirven siempre desde /sitemaps/*.xml y /sitemap-index.xml
# Nota: NO usar rewrite interno aquí — crea bucle con la regla de /sitemaps/ de abajo.
RewriteRule ^en/sitemap-index\.xml$ /sitemap-index.xml [R=301,L]
RewriteRule ^en/sitemaps/(.+\.xml)$ /sitemaps/$1 [R=301,L]

RewriteBase /

# No reescribir archivos estáticos reales ni index.html
RewriteRule ^index\.html$ - [L]

# Rutas con prefijo /en/ (idioma inglés) → SPA
RewriteRule ^en(/.*)?$ /index.html [L]

# Rutas de catálogo y búsqueda → SPA
RewriteRule ^catalogo(/.*)?$ /index.html [L]
RewriteRule ^catalog(/.*)?$ /index.html [L]

# Fallback general: cualquier ruta que no sea archivo/directorio real → SPA
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]