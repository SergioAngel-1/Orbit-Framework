# ============================================
# Starter Backend - WordPress + WooCommerce
# ============================================

# ============================================
# WORDPRESS CORE - NO VERSIONAR
# ============================================
app/public/wp-admin/
app/public/wp-includes/
app/public/wp-content/index.php
app/public/wp-content/plugins/index.php
app/public/wp-content/themes/index.php
app/public/index.php
app/public/readme.html
app/public/wp-*.php
app/public/xmlrpc.php

# ============================================
# CONFIGURACIÓN - DATOS SENSIBLES
# ============================================
app/public/wp-config.php
!app/public/wp-config.example.php
app/public/.htaccess
app/public/php.ini
app/public/.user.ini

# ============================================
# DATOS PROPIOS - NO VERSIONAR
# ============================================

# Uploads completos (imágenes de productos, banners, etc.)
app/public/wp-content/uploads/

# Cache y archivos temporales
app/public/wp-content/cache/
app/public/wp-content/backup*/
app/public/wp-content/backups/
app/public/wp-content/upgrade/
app/public/wp-content/w3tc-config/
app/public/wp-content/w3tc/
app/public/wp-content/advanced-cache.php
app/public/wp-content/db.php
app/public/wp-content/object-cache.php

# WooCommerce datos propios
app/public/wp-content/woocommerce-logs/
app/public/wp-content/wc-logs/
app/public/wp-content/woocommerce_uploads/

# Logs de errores
app/public/wp-content/debug.log
app/public/error_log
app/public/php_error.log

# ============================================
# PLUGINS - SOLO VERSIONAR CUSTOM
# ============================================

# Ignorar plugins de terceros (no custom)
app/public/wp-content/plugins/jwt-authentication-for-wp-rest-api/
app/public/wp-content/plugins/litespeed-cache/
app/public/wp-content/plugins/w3-total-cache/
app/public/wp-content/plugins/woocommerce/
app/public/wp-content/plugins/headless-mode/
app/public/wp-content/plugins/two-factor/

# Agregar aquí otros plugins de terceros que NO quieras versionar
# app/public/wp-content/plugins/nombre-del-plugin/

# NOTA: Todos los demás plugins SÍ se versionarán (se asume que son custom)

# ============================================
# THEMES - SOLO VERSIONAR CUSTOM
# ============================================

# Ignorar todos los themes
app/public/wp-content/themes/*

# Permitir solo el theme custom Starter
!app/public/wp-content/themes/Starter/

# Librerías de terceros dentro del tema (subir manualmente al servidor)
app/public/wp-content/themes/Starter/inc/lib/tcpdf/

# Themes de ejemplo siempre ignorados
app/public/wp-content/themes/twenty*/

# ============================================
# LANGUAGES - AUTO-GENERADOS
# ============================================
app/public/wp-content/languages/

# ============================================
# DATABASE & BACKUPS
# ============================================
*.sql
*.sql.gz
*.sqlite
*.db
*.dump
backups/
sql-dumps/

# Carpeta de SQL con backups de base de datos (DATOS PROPIOS)
app/sql/

# ============================================
# LOGS
# ============================================
*.log
error_log
debug.log
php_error.log

# ============================================
# OPERATING SYSTEM
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ============================================
# IDE & EDITORS
# ============================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ============================================
# COMPOSER (si usas)
# ============================================
vendor/
composer.lock

# ============================================
# NODE (si usas en backend)
# ============================================
node_modules/
package-lock.json
